{
  "displayName": "hs-tasnet-train",
  "jobSpec": {
    "workerPoolSpecs": [
      {
        "replicaCount": 1,
        "machineSpec": {
          "machineType": "g2-standard-4",
          "acceleratorType": "NVIDIA_L4",
          "acceleratorCount": 1
        },
        "diskSpec": {
          "bootDiskType": "pd-ssd",
          "bootDiskSizeGb": 200
        },
        "containerSpec": {
          "imageUri": "REGION-docker.pkg.dev/PROJECT/REPO/hs-tasnet:latest",
          "command": ["python", "scripts/vertex_worker.py"],
          "args": [
            "--cfg", "src/hs_tasnet/config/train.yaml",
            "--dataset-uri", "gs://YOUR_BUCKET/musdb18"
          ]
        }
      }
    ],
    "serviceAccount": "SERVICE_ACCOUNT_EMAIL"
  }
}
